# Copy this file to frontend/.env (or .env.local) for local dev.
# Every var must be prefixed VITE_ so Vite exposes it to the client
# bundle at build time — unprefixed vars are ignored on purpose.
#
# See frontend/src/lib/api.ts::resolveApiBase for the resolution rules.

# Optional API base URL.  Empty / unset = same-origin "/api", which
# is what the Vite dev proxy (vite.config.ts) expects in local dev.
#
# Production deploy patterns:
#   - Same-origin reverse proxy (nginx / Render / Cloudflare):
#       leave VITE_API_BASE_URL unset — requests go to /api/*, your
#       proxy rewrites them to the backend.
#   - Separate API host:
#       VITE_API_BASE_URL=https://api.example.com
#       and set CORS_ALLOWED_ORIGINS on the backend to the frontend
#       origin (e.g. https://app.example.com).
#
# Trailing slashes are stripped automatically.
VITE_API_BASE_URL=
