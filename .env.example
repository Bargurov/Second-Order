# Copy this file to .env for the current local app flow.
# The frontend does not currently require its own env vars.

# Optional for the API. Required only for real Anthropic-backed analysis.
# If omitted, the backend uses a mock fallback response for local analysis flows.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional backend model override for app runs and evals.
# Default if unset: claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Required only if you run the Telegram bot. Get a token from @BotFather.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# FastAPI base URL the Telegram bot calls during local runs.
SECOND_ORDER_API_URL=http://127.0.0.1:8000

# Optional scheduled morning brief. Enable only when all three are set.
DAILY_BRIEF_ENABLED=false
DAILY_BRIEF_CHAT_ID=your_telegram_chat_id_here
DAILY_BRIEF_TIME=08:00

# Optional watchlist alerts from saved-event tickers.
WATCHLIST_ENABLED=false
WATCHLIST_CHAT_ID=your_telegram_chat_id_here
WATCHLIST_INTERVAL_MIN=30
WATCHLIST_THRESHOLD_PCT=3.0
